# Praecantator Frontend Environment
# Copy this file to .env for local development.
# Vite exposes only variables prefixed with VITE_ to browser code.

# FastAPI backend
# Local backend default: http://127.0.0.1:8000
# Production example: https://your-api.example.com/api
VITE_API_URL=http://127.0.0.1:8000/api
VITE_API_BASE=http://127.0.0.1:8000/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Firebase Web app config.
# Leave blank when using local backend auth only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Maps and geocoding.
# Preferred Google Maps path: set GOOGLE_MAPS_API_KEY in Backend/.env;
# frontend uses /api/config/maps. This value is only a fallback.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GEOAPIFY_API_KEY=
VITE_MAPTILER_KEY=

# Optional map style overrides.
VITE_MAP_STYLE_DARK=
VITE_MAP_STYLE_LIGHT=

# Demo / local feature flags.
VITE_ENABLE_DEMO_MODE=true

# Worldmonitor data is fetched through Backend /api/global/*.
# Configure source keys in Backend/.env:
# FINNHUB_API_KEY, EIA_API_KEY, FRED_API_KEY, NEWSAPI_API_KEY,
# GNEWS_API_KEY, NASA_FIRMS_MAP_KEY, ACLED_EMAIL, ACLED_PASSWORD,
# OPENAQ_API_KEY, AVIATIONSTACK_API, AISSTREAM_API_KEY.
