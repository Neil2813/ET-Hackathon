# ============================================================
# Praecantator Backend — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# This .env.example file is safe to commit (all values are blank
# or non-sensitive defaults).
# ============================================================

ENVIRONMENT=development
DEV_MODE=true

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
AUTH_PROVIDER=local           # local | firebase
AUTH_OPTIONAL=true
LOCAL_AUTH_BYPASS=true
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ACCESS_TTL_MINUTES=525600
JWT_REFRESH_TTL_DAYS=365
DEV_USER_ID=local-dev-user
DEV_USER_EMAIL=dev@local.example.com
DEV_USER_ROLE=admin
DEV_TENANT_ID=demo-tenant

# ---------------------------------------------------------------------------
# Persistence & Cache
# ---------------------------------------------------------------------------
DB_PROVIDER=local             # local | firestore
FIRESTORE_ENABLED=false
LOCAL_DB_PATH=local_fallback.db
CACHE_PROVIDER=memory         # memory | redis
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=

# ---------------------------------------------------------------------------
# LLM Providers  (leave blank to use local fallback)
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq             # groq | gemini | local
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Google Cloud / Firebase
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_ADMIN_ENABLED=false

# ---------------------------------------------------------------------------
# Maps & Routing
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_USE_LIVE=false

# ---------------------------------------------------------------------------
# WorldMonitor data sources  (all optional — free tiers used when blank)
# ---------------------------------------------------------------------------
WORLDMONITOR_FETCHER_ENABLED=true
WORLDMONITOR_READ_CACHE_SECONDS=300
NEWSAPI_API_KEY=
GNEWS_API_KEY=
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_API_KEY=
FINNHUB_API_KEY=
EIA_API_KEY=
FRED_API_KEY=
OPENAQ_API_KEY=
AVIATIONSTACK_API=
AISSTREAM_API_KEY=
ACLED_API_KEY=
ACLED_EMAIL=
ACLED_PASSWORD=
ACLED_ACCESS_TOKEN=
IEA_BULLETINS_URL=https://api.iea.org/v1/reports
OPEC_MEETING_FEED=https://www.opec.org/opec_web/en/press_room.xml
SANCTIONS_REGISTRY_OFAC=https://api.trade.gov/consolidated_screening_list/search
LLOYDS_LIST_MARITIME_ALERT=https://api.lloydslistintelligence.com/alerts
TANKER_AIS_INGESTION_STREAM=wss://stream.aisstream.io/v1/vessels/india-bound
BRENT_FUTURE_CURVE_API=https://api.eia.gov/v2/petroleum/pri/spt/data/
WTO_API_KEY=
CLOUDFLARE_API_TOKEN=

# ---------------------------------------------------------------------------
# Energy Resilience Module
# ---------------------------------------------------------------------------
ENERGY_RESILIENCE_USE_LIVE_APIS=true
ENERGY_RESILIENCE_API_TIMEOUT_SECONDS=8
ENERGY_RESILIENCE_GDELT_URL=https://api.gdeltproject.org/api/v2/doc/doc
ENERGY_RESILIENCE_PORTWATCH_URL=https://services9.arcgis.com/weJ1QsnbMYJlCHdG/arcgis/rest/services/Daily_Chokepoints_Data/FeatureServer/0/query
ENERGY_RESILIENCE_EIA_BRENT_URL=https://api.eia.gov/v2/petroleum/pri/spt/data/

# ---------------------------------------------------------------------------
# Schedulers & Incident Lifecycle
# ---------------------------------------------------------------------------
ENABLE_IN_PROCESS_SCHEDULERS=true
ENABLE_SIGNAL_SCHEDULER=true
SIGNAL_POLL_INTERVAL_MINUTES=10
WORLDMONITOR_REFRESH_INTERVAL_SECONDS=900
INCIDENT_ACTIVE_TTL_HOURS=168
INCIDENT_RESOLVED_TTL_DAYS=7
SCHEDULER_TASK_LOCK_TTL_SECONDS=540

# ---------------------------------------------------------------------------
# Intelligence Gap Tracker
# ---------------------------------------------------------------------------
INTELLIGENCE_GAP_TRACKER_ENABLED=true
INTELLIGENCE_GAP_CONTEXT_QUALITY_MIN=75
INTELLIGENCE_GAP_SIGNAL_STALE_HOURS=24

# ---------------------------------------------------------------------------
# Threshold Tuning
# ---------------------------------------------------------------------------
THRESHOLD_TUNING_MIN_SAMPLES=10
THRESHOLD_TUNING_TARGET_F1=0.80
THRESHOLD_TUNING_MAX_STEP=0.05

# ---------------------------------------------------------------------------
# Mail / RFQ Integrations  (disabled by default for local demo)
# ---------------------------------------------------------------------------
GMAIL_API_ENABLED=false
GMAIL_OAUTH_ACCESS_TOKEN=
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------------------------------------------------------------------------
# Testing & Demo Controls
# ---------------------------------------------------------------------------
FORCE_DEGRADED_MODE=false
